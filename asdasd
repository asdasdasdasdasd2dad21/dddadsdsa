-- ==========================================
-- FIXED ESP INTEGRATION (No external dependencies)
-- ==========================================

-- Load ESP library
local MatchaEsp = loadstring(game:HttpGet('https://raw.githubusercontent.com/alebinh60/asmobile/refs/heads/main/esplib'))()
local esp = MatchaEsp

-- Initialize ESP
esp:Initialize()

-- Create column in Visuals tab
local espColumn = Visuals:column()

-- BOX ESP
local boxSection = espColumn:section({name = "Box ESP"})
boxSection:toggle({name = "Box ESP", default = false, callback = function(v) esp.State.BoxEnabled = v end})
boxSection:colorpicker({name = "Box Color", color = Color3.new(0.4, 0.35, 0.7), callback = function(c) esp.Config.BoxColor = c end})
boxSection:toggle({name = "Box Outline", default = true, callback = function(v) esp.Config.BoxOutlineEnabled = v end})
boxSection:slider({name = "Fill Transparency", min = 0, max = 1, default = 0.5, callback = function(v) esp.Config.BoxFillTransparency = v end})

-- RING ESP
local ringSection = espColumn:section({name = "Ring ESP"})
ringSection:toggle({name = "Ring ESP", default = false, callback = function(v) if v then esp:InitiateRing(Color3.new(1,1,1)) else esp.State.RingEnabled = false end end})
ringSection:colorpicker({name = "Ring Color", color = Color3.new(1,1,1), callback = function(c) esp.Config.RingColor = c end})

-- NAME ESP
local nameSection = espColumn:section({name = "Name ESP"})
nameSection:toggle({name = "Name ESP", default = false, callback = function(v) esp:InitiateName(v) end})

-- DISTANCE ESP
local distSection = espColumn:section({name = "Distance ESP"})
distSection:toggle({name = "Distance ESP", default = false, callback = function(v) esp:InitiateDistance(v) end})

-- SKELETON ESP
local skeletonSection = espColumn:section({name = "Skeleton ESP"})
skeletonSection:toggle({name = "Skeleton ESP", default = false, callback = function(v) if v then esp:InitiateSkeleton(Color3.new(0.4,0.35,0.7)) else esp.State.SkeletonEnabled = false end end})
skeletonSection:colorpicker({name = "Skeleton Color", color = Color3.new(0.4,0.35,0.7), callback = function(c) esp.Config.SkeletonColor = c end})

-- HEALTH BAR ESP
local healthSection = espColumn:section({name = "Health Bar ESP"})
healthSection:toggle({name = "Health Bar", default = false, callback = function(v) esp.State.HealthBarEnabled = v end})
healthSection:toggle({name = "Health Text", default = false, callback = function(v) esp.State.HealthTextEnabled = v end})
healthSection:slider({name = "Smoothness", min = 0.05, max = 0.5, default = 0.15, callback = function(v) esp.Config.HealthBarLerpSpeed = v end})

-- TRACER ESP
local tracerSection = espColumn:section({name = "Tracer ESP"})
tracerSection:toggle({name = "Tracer ESP", default = false, callback = function(v) if v then esp:InitiateTracer(Color3.new(0.4,0.35,0.7), "Bottom Screen") else esp.State.TracerEnabled = false end end})
tracerSection:colorpicker({name = "Tracer Color", color = Color3.new(0.4,0.35,0.7), callback = function(c) esp.Config.TracerColor = c end})
tracerSection:dropdown({name = "Tracer Origin", default = "Bottom Screen", items = {"Bottom Screen", "Cursor", "Top Screen"}, callback = function(v) esp.Config.TracerOrigin = v end})

-- CHAMS ESP
local chamsSection = espColumn:section({name = "Chams ESP"})
chamsSection:toggle({name = "Chams", default = false, callback = function(v) if v then esp:InitiateChams(Color3.new(0.4,0.35,0.7)) else esp.State.ChamsEnabled = false end end})
chamsSection:colorpicker({name = "Fill Color", color = Color3.new(0.4,0.35,0.7), callback = function(c) esp.Config.ChamsColor = c end})
chamsSection:colorpicker({name = "Outline Color", color = Color3.new(1,1,1), callback = function(c) esp.Config.ChamsOutlineColor = c end})
chamsSection:slider({name = "Transparency", min = 0, max = 1, default = 0.5, callback = function(v) esp.Config.ChamsFillTransparency = v end})

-- TEAM CHECK
local teamSection = espColumn:section({name = "Team Check"})
teamSection:toggle({name = "Team Check", default = true, callback = function(v) esp:TeamCheck(v) end})

-- ESP DISTANCE
local distLimitSection = espColumn:section({name = "ESP Distance"})
distLimitSection:slider({name = "Max Distance", min = 100, max = 1000, default = 1000, suffix = " studs", callback = function(v) esp:SetDistance(v) end})

print("ESP System loaded!")
